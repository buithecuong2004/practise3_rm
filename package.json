{
  "name": "practise3_remake",
  "version": "1.0.0",
  "description": "Project with BEM, SCSS, Bootstrap, and jQuery",
  "main": "index.html",
  "scripts": {
    "sass:watch": "sass --watch scss/main.scss assets/css/main.css",
    "sass:build": "sass scss/main.scss assets/css/main.css --style compressed",
    "serve": "browser-sync start --server --files 'index.html, assets/css/*.css, assets/js/*.js'",
    "dev": "npm-run-all --parallel sass:watch serve"
  },
  "dependencies": {
    "bootstrap": "^5.3.3",
    "jquery": "^3.7.1"
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "npm-run-all": "^4.1.5",
    "sass": "^1.75.0"
  }
}
